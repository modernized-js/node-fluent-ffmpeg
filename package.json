{
  "name": "@modernized/fluent-ffmpeg",
  "version": "0.1.2",
  "description": "A fluent API to FFMPEG (http://www.ffmpeg.org) — modernized fork in TypeScript",
  "keywords": [
    "ffmpeg"
  ],
  "author": "Stefan Schaermeli <schaermu@gmail.com>",
  "contributors": [
    {
      "name": "Felix Fichte",
      "email": "spruce@space-ships.de"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/modernized-js/node-fluent-ffmpeg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modernized-js/node-fluent-ffmpeg.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "which": "^6.0.1"
  },
  "resolutions": {
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/which": "^3.0.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "prettier": "^3.4.2",
    "tsd": "^0.33.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "yarn build",
    "test": "node --import tsx --test --test-reporter=spec \"test/**/*.test.ts\"",
    "test:types": "tsd"
  },
  "tsd": {
    "directory": "test-d"
  }
}
