{
  "name": "@modernized/fluent-ffmpeg",
  "version": "3.0.0-pre.0",
  "description": "A fluent API to FFMPEG (http://www.ffmpeg.org) — modernized fork",
  "keywords": [
    "ffmpeg"
  ],
  "author": "Stefan Schaermeli <schaermu@gmail.com>",
  "contributors": [
    {
      "name": "Felix Fichte",
      "email": "spruce@space-ships.de"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/isamu/node-fluent-ffmpeg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isamu/node-fluent-ffmpeg.git"
  },
  "main": "index.js",
  "files": [
    "lib",
    "index.js",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "async": "^0.2.9",
    "which": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/which": "^3.0.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "prettier": "^3.4.2",
    "should": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "node --import tsx --test --test-reporter=spec \"test/**/*.test.ts\"",
    "test:legacy": "NODE_ENV=test NODE_OPTIONS='--import tsx' mocha --require should --reporter spec test/*.test.js",
    "coverage": "nyc report --reporter=lcov"
  }
}
